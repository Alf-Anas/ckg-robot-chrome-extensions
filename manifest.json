{
    "manifest_version": 3,
    "name": "CKG Robot",
    "version": "3.0",

    "action": {
        "default_icon": {
            "16": "icon.png",
            "48": "icon.png",
            "128": "icon.png"
        }
    },

    "side_panel": {
        "default_path": "panel.html"
    },

    "permissions": ["storage", "scripting", "activeTab", "tabs", "sidePanel"],

    "host_permissions": ["<all_urls>"],

    "background": {
        "service_worker": "background.js"
    },

    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["helper.js"]
        }
    ]
}
